---
import { getEmDashCollection, getSiteSettings } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";

// Fetch settings + the 4 featured projects in parallel. Limiting and
// sorting in the database avoids loading every project just to slice
// off the first 4 in JS (a full-table read on sites with lots of work).
const [
	settings,
	{ entries: featuredProjects, cacheHint },
	{ entries: profiles },
	{ entries: abouts },
	{ entries: skills },
	{ entries: experiences },
] = await Promise.all([
	getSiteSettings(),
	getEmDashCollection("projects", {
		orderBy: { published_at: "desc" },
		limit: 4,
	}),
	getEmDashCollection("profiles"),
	getEmDashCollection("abouts"),
	getEmDashCollection("skills"),
	getEmDashCollection("experiences"),
]);

const profile = profiles[0];
const about = abouts[0];
const skill = skills[0];
const experience = experiences[0];

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Base>
	<section class="hero">
		<h1 class="hero-title">
			{profile?.data.name || settings?.title || "Studio"}
		</h1>
		<p class="hero-tagline">
			{profile?.data.title || settings?.tagline || "Design & Development"}
		</p>
		{
			profile?.data.intro && (
				<div class="hero-intro">
					<PortableText value={profile.data.intro} />
				</div>
			)
		}
		{
			profile?.data.resume_url && (
				<a href={profile.data.resume_url} class="btn" target="_blank">
					Download Resume
				</a>
			)
		}
	</section>

	{
		about?.data.content && (
			<section class="about" id="about">
				<h2 class="section-title">About Me</h2>
				<div class="about-content">
					<PortableText value={about.data.content} />
				</div>
			</section>
		)
	}

	{
		skills.length > 0 && (
			<section class="skills">
				<h2 class="section-title">Skills</h2>
				<div class="skills-grid">
					{skills.map((skill) => (
						<div class="skill-item">
							<span class="skill-name">{skill.data.name}</span>
							{skill.data.category && (
								<span class="skill-category">
									{skill.data.category}
								</span>
							)}
							{skill.data.level && (
								<span class="skill-level">
									{skill.data.level}
								</span>
							)}
						</div>
					))}
				</div>
			</section>
		)
	}

	{
		featuredProjects.length > 0 ? (
			<section class="featured">
				<header class="section-header">
					<h2 class="section-title">Selected Work</h2>
					<a href="/work" class="section-link">
						View all projects &rarr;
					</a>
				</header>
				<div class="projects-grid">
					{featuredProjects.map((project) => (
						<ProjectCard
							title={project.data.title ?? "Untitled"}
							summary={project.data.summary}
							featuredImage={project.data.featured_image ?? ""}
							href={`/work/${project.id}`}
							client={project.data.client}
							year={project.data.year}
						/>
					))}
				</div>
			</section>
		) : (
			<section class="empty-state">
				<h2>No projects yet</h2>
				<p>Add your first project in the admin panel.</p>
				<a href="/_emdash/admin/content/projects/new" class="btn">
					Add a project
				</a>
			</section>
		)
	}

	{
		experiences.length > 0 && (
			<section class="experience">
				<h2 class="section-title">Experience</h2>
				<div class="experience-list">
					{experiences.map((exp) => (
						<div class="experience-item">
							<div class="experience-header">
								<h3 class="experience-role">{exp.data.role}</h3>
								<span class="experience-dates">
									{exp.data.start_date} – {exp.data.end_date}
								</span>
							</div>
							<p class="experience-company">{exp.data.company}</p>
							{exp.data.description && (
								<p class="experience-description">
									{exp.data.description}
								</p>
							)}
						</div>
					))}
				</div>
			</section>
		)
	}
</Base>

<style>
	.hero {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
		text-align: center;
	}

	.hero-intro {
		font-size: var(--font-size-md);
		color: var(--color-muted);
		max-width: 600px;
		margin: var(--spacing-md) auto 0;
	}

	.hero-title {
		font-size: var(--font-size-4xl);
		font-weight: 500;
		margin-bottom: var(--spacing-md);
		letter-spacing: -0.02em;
	}

	.hero-tagline {
		font-size: var(--font-size-xl);
		color: var(--color-muted);
		font-family: var(--font-serif);
		font-style: italic;
	}

	.about {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-lg) var(--spacing-4xl);
	}

	.about-content {
		font-size: var(--font-size-md);
		color: var(--color-muted);
		max-width: 700px;
		line-height: 1.7;
	}

	.featured {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-lg) var(--spacing-4xl);
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: var(--spacing-2xl);
		padding-bottom: var(--spacing-md);
		border-bottom: 1px solid var(--color-border);
	}

	.section-title {
		font-size: var(--font-size-lg);
		font-weight: 500;
		padding-bottom: 10px;
	}

	.section-link {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.section-link:hover {
		color: var(--color-text);
	}

	.skills {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-lg) var(--spacing-4xl);
	}

	.skills-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-md);
	}

	.skill-item {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-xs);
		padding: var(--spacing-md);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
	}

	.skill-name {
		font-weight: 500;
		font-size: var(--font-size-md);
	}

	.skill-category {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.skill-level {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		font-style: italic;
	}

	@media (max-width: 768px) {
		.skills-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.experience {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-lg) var(--spacing-4xl);
	}

	.experience-list {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2xl);
	}

	.experience-item {
		padding: var(--spacing-lg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
	}

	.experience-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: var(--spacing-xs);
	}

	.experience-role {
		font-size: var(--font-size-md);
		font-weight: 500;
	}

	.experience-dates {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.experience-company {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-sm);
	}

	.experience-description {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		line-height: 1.7;
	}

	@media (max-width: 768px) {
		.experience-header {
			flex-direction: column;
			gap: var(--spacing-xs);
		}
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-2xl);
	}

	.empty-state {
		text-align: center;
		padding: var(--spacing-4xl) var(--spacing-lg);
		max-width: 400px;
		margin: 0 auto;
	}

	.empty-state h2 {
		font-size: var(--font-size-xl);
		margin-bottom: var(--spacing-sm);
	}

	.empty-state p {
		color: var(--color-muted);
		margin-bottom: var(--spacing-lg);
	}

	.btn {
		display: inline-block;
		padding: var(--spacing-sm) var(--spacing-lg);
		background: var(--color-text);
		color: var(--color-bg);
		text-decoration: none;
		border-radius: var(--radius);
		font-size: var(--font-size-sm);
		transition: opacity var(--transition-fast);
	}

	.btn:hover {
		opacity: 0.85;
	}

	@media (max-width: 768px) {
		.hero {
			padding: var(--spacing-3xl) var(--spacing-lg);
		}

		.hero-title {
			font-size: var(--font-size-3xl);
		}

		.projects-grid {
			grid-template-columns: 1fr;
		}

		.section-header {
			flex-direction: column;
			gap: var(--spacing-sm);
			align-items: flex-start;
		}
	}
</style>
